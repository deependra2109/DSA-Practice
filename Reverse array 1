  class Solution {
    public void reverseArray(int arr[]) {
        int l = arr.length;
        int[] rev = new int[l];

        for (int i = 0; i < l; i++) {
            int j = l - 1 - i;
            rev[j] = arr[i];
        }
 for (int i = 0; i < l; i++) {
            arr[i] = rev[i];
        }
        
        }
    
}
