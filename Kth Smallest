
class Solution {
    public static int kthSmallest(int[] arr, int k) {
        // Your code here
        int l=arr.length;
        
     for(int i=0; i<l;i++){
        for(int j=i+1; j<l;j++){
            if(arr[i]>arr[j]){
                int temp=arr[j];
                arr[j]=arr[i];
                arr[i]=temp;
            }
        }
    }

     
        return arr[k-1];
    }
}
